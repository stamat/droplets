{
    "title": "System Monitor",
    "description": "CPU, memory, disk and network usage on macOS and Linux",
    "type": "widget",
    "origin": "local",
    "allowed_methods": ["stats"],
    "options": {
        "poll_seconds": {
            "type": "int",
            "label": "Refresh every",
            "description": "Seconds between samples.",
            "default": 1,
            "min": 1,
            "max": 60
        },
        "net_units": {
            "type": "enum",
            "label": "Network units",
            "choices": ["bytes", "bits"],
            "default": "bytes"
        }
    },
    "width": 200,
    "height": 210,
    "shape": "roundedrect",
    "corner_radius": 10,
    "transparent": true,
    "decorated": false,
    "drag": true,
    "stick": true,
    "below": true,
    "skip_taskbar": true,
    "skip_pager": true
}
